        "defaults": {
          "mappings": [
            { "id": 0, "op": "=", "text": "DOWN", "type": 1, "value": "0" },
            { "id": 1, "op": "=", "text": "UP", "type": 1, "value": "1" }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "text": {},
        "textMode": "auto"
      },
      "targets": [{ "expr": "probe_success{job=\"blackbox\"}", "refId": "A" }],
      "title": "Application Uptime (Live)",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10, "lineWidth": 2 },
          "unit": "s"
        }
      },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 6 },
      "id": 2,
      "targets": [{ "expr": "probe_duration_seconds{job=\"blackbox\"}", "legendFormat": "Response Time (Seconds)", "refId": "A" }],
      "title": "Response Latency",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 300 },
              { "color": "red", "value": 400 }
            ]
          }
        }
      },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 15 },
      "id": 3,
      "options": {
        "colorMode": "value",
        "justifyMode": "center",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [{ "expr": "probe_http_status_code{job=\"blackbox\"}", "refId": "A" }],
      "title": "Last HTTP Status Code",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "decbytes" }
      },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 15 },
      "id": 4,
      "options": {
        "colorMode": "value",
        "justifyMode": "center",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [{ "expr": "probe_http_content_length{job=\"blackbox\"}", "refId": "A" }],
      "title": "Response Size",
      "type": "stat"
    }
